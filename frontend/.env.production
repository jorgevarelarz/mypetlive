# En producción el frontend se sirve desde el mismo dominio que el API (proxy
# Apache /api -> contenedor). Dejar REACT_APP_API_URL vacío hace que el cliente
# axios use window.location.origin (ver src/api/client.ts), evitando que el build
# herede el http://localhost:3000 del .env de desarrollo.
REACT_APP_API_URL=
